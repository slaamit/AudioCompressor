<Window x:Class="AudioCompressor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:vm="clr-namespace:AudioCompressor.ViewModels"
        Title="Audio Compressor" Height="860" Width="950"
        AllowDrop="True" Drop="Window_Drop">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- شريط الأزرار -->
            <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                <Button Command="{Binding LoadCommand}" Content="Load Audio" Padding="10,5" Margin="0,0,5,0"/>
                <Button Command="{Binding PlayCommand}" Content="Play Original" Padding="10,5" Margin="0,0,5,0"/>
                <Button Command="{Binding StopCommand}" Content="Stop" Padding="10,5" Margin="0,0,5,0"/>
                <Separator Width="1" Background="Gray" Margin="5,0"/>
                <Button Command="{Binding PlayDecompressedCommand}" Content="Play Decompressed" Padding="10,5" Margin="0,0,5,0" Background="LightBlue"/>
                <Separator Width="1" Background="Gray" Margin="5,0"/>
                <Button Command="{Binding CompressCommand}" Content="Compress" Padding="10,5" Margin="0,0,5,0" Background="LightGreen"/>
                <Button Command="{Binding CancelCompressCommand}" Content="Cancel" Padding="10,5" Margin="0,0,5,0" Background="#FFCCCC"/>
                <Button Command="{Binding ResetCommand}" Content="Reset" Padding="10,5" Margin="0,0,5,0"/>
                <Separator Width="1" Background="Gray" Margin="5,0"/>
                <Button Command="{Binding DecompressFromFileCommand}" Content="Load Compressed File" Padding="10,5" Margin="0,0,5,0"/>
                <Button Command="{Binding DecompressLoadedCommand}" Content="Decompress Loaded" Padding="10,5" Margin="0,0,5,0"/>
                <Button Command="{Binding SaveCompressedCommand}" Content="Save Compressed" Padding="10,5"/>
            </WrapPanel>

            <!-- خصائص الملف -->
            <GroupBox Header="Audio Properties" Grid.Row="1" Margin="0,5">
                <TextBlock Text="{Binding AudioInfo}" TextWrapping="Wrap" Margin="5"/>
            </GroupBox>

            <!-- Waveform -->
            <GroupBox Header="Audio Waveform" Grid.Row="2" Margin="0,5">
                <oxy:PlotView Model="{Binding WaveformModel}" Height="150" Margin="5"/>
            </GroupBox>

            <!-- إعدادات الضغط -->
            <GroupBox Header="Compression Settings" Grid.Row="3" Margin="0,5">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Algorithm:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox ItemsSource="{Binding Algorithms}" SelectedItem="{Binding SelectedAlgorithm}" Width="200" Margin="5"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Quantization Levels:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Text="{Binding QuantizationLevels}" Width="100" Margin="5"/>
                    </StackPanel>
                    <Button Command="{Binding CompressCommand}" Content="Compress" Padding="10,5" Margin="5" Background="LightGreen"/>
                </StackPanel>
            </GroupBox>

            <!-- شريط التقدم والمؤشرات -->
            <StackPanel Grid.Row="4" Margin="0,5">
                <ProgressBar Height="25" Value="{Binding ProgressValue}" Minimum="0" Maximum="100"/>
                <TextBlock Text="{Binding StatusMessage}" Margin="5" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Compression Ratio: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding CompressionRatioText}" Width="80"/>
                    <TextBlock Text="    Speed: " FontWeight="Bold" Margin="20,0,0,0"/>
                    <TextBlock Text="{Binding SpeedText}" Width="120"/>
                </StackPanel>
            </StackPanel>

            <!-- التقرير والرسم البياني -->
            <GroupBox Header="Compression Report Graph" Grid.Row="5" Margin="0,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding ReportText}" TextWrapping="Wrap" FontFamily="Consolas" Margin="5" Background="#F0F0F0"/>
                    <oxy:PlotView Grid.Row="1" Model="{Binding CompressionPlotModel}" Height="220" Margin="5"/>
                </Grid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</Window>